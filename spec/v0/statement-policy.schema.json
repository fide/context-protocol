{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fide.work/context-protocol/v0/statement-policy.schema.json",
  "title": "Fide Context Protocol Statement Policy v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "$id",
    "namespaceUrl",
    "specVersion",
    "specDate",
    "propertyRole",
    "statementNormalizationRules",
    "forbiddenProperties",
    "typeAssertionProperties",
    "guideExamples"
  ],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "$id": { "type": "string", "format": "uri" },
    "namespaceUrl": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "specVersion": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "specDate": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "propertyRole": {
      "$ref": "#/$defs/propertyRole"
    },
    "statementNormalizationRules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/statementNormalizationRule"
      }
    },
    "forbiddenProperties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleWithProperty"
      }
    },
    "typeAssertionProperties": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri",
        "pattern": "^https://"
      }
    },
    "guideExamples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/guideExample"
      }
    }
  },
  "$defs": {
    "statementRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityType", "referenceType", "referenceIdentifier"],
      "properties": {
        "entityType": {
          "type": "string",
          "minLength": 1
        },
        "referenceType": {
          "type": "string",
          "minLength": 1
        },
        "referenceIdentifier": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "guideStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "property", "object"],
      "properties": {
        "subject": {
          "$ref": "#/$defs/statementRole"
        },
        "property": {
          "$ref": "#/$defs/statementRole"
        },
        "object": {
          "$ref": "#/$defs/statementRole"
        }
      }
    },
    "guideExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleId", "strength", "reason", "discouraged", "preferred"],
      "properties": {
        "ruleId": {
          "type": "string",
          "minLength": 1
        },
        "strength": {
          "type": "string",
          "enum": ["SHOULD", "MAY"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "discouraged": {
          "$ref": "#/$defs/guideStatement"
        },
        "preferred": {
          "oneOf": [
            { "$ref": "#/$defs/guideStatement" },
            { "type": "null" }
          ]
        }
      }
    },
    "ruleWithProperty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "propertyIri", "description", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "propertyIri": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "propertyRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityTypes", "referenceType", "description", "path"],
      "properties": {
        "entityTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "DirectionalProperty",
              "SymmetricProperty"
            ]
          }
        },
        "referenceType": {
          "const": "NetworkResource"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "statementNormalizationRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "path"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
