{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fide.work/context-protocol/v0/statement.schema.json",
  "title": "Fide Context Protocol Statement v0",
  "description": "Canonical statement object for Fide Context Protocol v0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "subjectFideId",
    "subjectReferenceIdentifier",
    "propertyFideId",
    "propertyReferenceIdentifier",
    "objectFideId",
    "objectReferenceIdentifier"
  ],
  "properties": {
    "subjectFideId": {
      "$ref": "#/$defs/fideId"
    },
    "subjectReferenceIdentifier": {
      "$ref": "#/$defs/referenceIdentifier"
    },
    "propertyFideId": {
      "$ref": "#/$defs/fideId"
    },
    "propertyReferenceIdentifier": {
      "$ref": "#/$defs/referenceIdentifier"
    },
    "objectFideId": {
      "$ref": "#/$defs/fideId"
    },
    "objectReferenceIdentifier": {
      "$ref": "#/$defs/referenceIdentifier"
    },
    "statementFideId": {
      "$ref": "#/$defs/fideId"
    }
  },
  "$defs": {
    "fideId": {
      "type": "string",
      "pattern": "^did:fide:0x[0-9a-fA-F]{40}$"
    },
    "referenceIdentifier": {
      "type": "string",
      "minLength": 1
    }
  }
}
